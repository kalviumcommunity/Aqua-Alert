    "required_folders = [\n",
    "    root / \"data\",\n",
    "    root / \"data\" / \"raw\",\n",
    "    root / \"data\" / \"processed\",\n",
    "    root / \"notebooks\",\n",
    "    root / \"scripts\",\n",
    "    root / \"outputs\",\n",
    "]\n",
    "\n",
    "for folder in required_folders:\n",
    "    status = \"OK\" if folder.exists() else \"MISSING\"\n",
    "    print(f\"[{status}] {folder}\")"
   ]
